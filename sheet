/**
 * STEP 1: Setup the sheet. Run this manually once.
 */
function setupSheetHeaders() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName("Orders") || ss.insertSheet("Orders");
  
  const headers = [
    "Order ID (PK)", "Flags", "Order Date", "Last Updated", "Customer Name", 
    "Email", "Phone", "Channel", "Total", "Payment status", 
    "Fulfillment status", "Items", "Tags", "City", "Shipment Status", 
    "Tracking Company", "Tracking Number"
  ];
  
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  sheet.setFrozenRows(1);
}

/**
 * STEP 2: The Main Webhook Handler
 */
function doPost(e) {
  const lock = LockService.getScriptLock();
  try {
    lock.waitLock(30000); 
  } catch (e) {
    return ContentService.createTextOutput("Error: Could not obtain lock (Timeout)");
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName("Orders") || ss.insertSheet("Orders");
  
  try {
    if (!e || !e.postData) return;
    const data = JSON.parse(e.postData.contents);

    const primaryKey = String(data.name || data.order_id || "").trim().split('.')[0]; 
    if (!primaryKey) throw new Error("No Unique ID found in payload");

    const lastRow = sheet.getLastRow();
    let rowIndex = -1;
    let existingRowData = [];

    if (lastRow > 1) {
      const ids = sheet.getRange(2, 1, lastRow, 1).getValues().flat().map(id => String(id).trim());
      rowIndex = ids.indexOf(primaryKey);
      if (rowIndex !== -1) {
        existingRowData = sheet.getRange(rowIndex + 2, 1, 1, 17).getValues()[0];
      }
    }

    // --- TOTAL PRICE CALCULATION ---
    let totalPrice = data.total_price;
    if (!totalPrice && data.line_items) {
      totalPrice = data.line_items.reduce((sum, item) => sum + (parseFloat(item.price || 0) * (item.quantity || 1)), 0);
    }
    totalPrice = totalPrice || (existingRowData[8] || 0);

    // --- INTEGRATED STATUS & TRACKING LOGIC ---
    let shipStatus, fulfillStatus, payStatus, carrier, trackingNum;
    
    // Check if order is cancelled
    if (existingRowData[14] === "CANCELLED" || data.cancelled_at || data.cancel_reason) {
      shipStatus = "CANCELLED";
      fulfillStatus = "CANCELLED";
      payStatus = "voided";
      carrier = "N/A";
      trackingNum = "CANCELLED";
    } else {
      // 1. Determine Payment and Fulfillment Status
      payStatus = data.financial_status || (existingRowData[9] || "pending");
      fulfillStatus = data.status || (existingRowData[10] || "unfulfilled");

      // 2. Extract Tracking Info from webhook or fallback to existing
      carrier = data.tracking_company || (data.fulfillments ? data.fulfillments[0]?.tracking_company : (existingRowData[15] || ""));
      trackingNum = data.tracking_number || (data.fulfillments ? data.fulfillments[0]?.tracking_number : (existingRowData[16] || ""));

      // 3. APPLY CUSTOM PICKUP LOGIC: Success but no tracking
      if (fulfillStatus === "success" && (!trackingNum || trackingNum === "null" || trackingNum === "undefined" || trackingNum === "")) {
        shipStatus = "N/A";
        trackingNum = "undefined"; // Explicitly set per requirement
        carrier = ""; // Blank if not assigned
      } else {
        shipStatus = data.shipment_status || (existingRowData[14] || "N/A");
        trackingNum = trackingNum || "undefined";
      }
    }

    // --- DATA EXTRACTION ---
    const orderDate = existingRowData.length > 0 ? existingRowData[2] : (data.created_at ? new Date(data.created_at) : new Date());
    const lastUpdated = new Date(); 
    const customer = data.destination?.name || (data.customer ? (data.customer.first_name + " " + data.customer.last_name) : (existingRowData[4] || "N/A"));
    const email = data.email || existingRowData[5] || "N/A";
    const phone = data.destination?.phone || data.customer?.phone || (existingRowData[6] || "N/A");
    const city = data.destination?.city || existingRowData[13] || "N/A";
    const finalOrderID = existingRowData.length > 0 ? existingRowData[0] : primaryKey;
    const finalItems = existingRowData.length > 0 ? existingRowData[11] : (data.line_items ? data.line_items.map(item => item.quantity + "x " + item.title).join(", ") : "N/A");

    // --- ASSEMBLE ROW ---
    const rowData = [
      finalOrderID,      // Col 1
      "low",             // Col 2
      orderDate,         // Col 3
      lastUpdated,       // Col 4
      customer,          // Col 5
      email,             // Col 6
      "'" + phone,       // Col 7
      data.source_name || (existingRowData[7] || "web"), // Col 8
      totalPrice,        // Col 9
      payStatus,         // Col 10
      fulfillStatus,     // Col 11
      finalItems,        // Col 12
      data.tags || (existingRowData[12] || ""),          // Col 13
      city,              // Col 14
      shipStatus,        // Col 15
      carrier,           // Col 16
      "'" + trackingNum  // Col 17
    ];

    if (rowIndex !== -1) {
      sheet.getRange(rowIndex + 2, 1, 1, rowData.length).setValues([rowData]);
    } else {
      sheet.insertRowAfter(1);
      sheet.getRange(2, 1, 1, rowData.length).setValues([rowData]);
    }

    sheet.getRange(2, 3, sheet.getLastRow() > 1 ? sheet.getLastRow() - 1 : 1, 2).setNumberFormat("dd/mm/yyyy hh:mm:ss am/pm");

    return ContentService.createTextOutput("Success - PK: " + primaryKey);

  } catch (err) {
    console.error(err.toString());
    return ContentService.createTextOutput("Error: " + err.message);
  } finally {
    lock.releaseLock();
  }
}

/**
 * STEP 3: The Delay Scanner
 */
function updateDelayOrderSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sourceSheet = ss.getSheetByName("Orders");
  const delaySheet = ss.getSheetByName("Delay_Order") || ss.insertSheet("Delay_Order");
  
  if (!sourceSheet) return;

  const lastRow = sourceSheet.getLastRow();
  if (lastRow < 2) return;

  const data = sourceSheet.getRange(2, 1, lastRow - 1, 17).getValues();
  const headers = sourceSheet.getRange(1, 1, 1, 17).getValues();
  const today = new Date();
  const delayedRows = [];

  for (let i = 0; i < data.length; i++) {
    const rawDate = data[i][2];
    if (!rawDate || isNaN(Date.parse(rawDate))) continue;
    
    const orderDate = new Date(rawDate); 
    const shipStatus = String(data[i][14]).trim().toLowerCase();
    const trackNum = String(data[i][16]).trim().toLowerCase();
    
    const diffTime = today.getTime() - orderDate.getTime();
    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

    // Logic: If not delivered/cancelled AND (Delayed 4+ days OR Success but undefined tracking)
    if (shipStatus !== "delivered" && shipStatus !== "cancelled") {
      if (diffDays >= 4 || trackNum.includes("undefined")) {
        let row = [...data[i]];
        
        // Flag logic
        let flagSymbol = "🟡"; 
        if (diffDays >= 6 || (trackNum.includes("undefined") && diffDays >= 3)) flagSymbol = "🔴";
        else if (diffDays === 5) flagSymbol = "🟠";
        
        row[1] = flagSymbol + " " + diffDays + " Days";
        delayedRows.push(row);
      }
    }
  }

  delaySheet.clear(); 
  delaySheet.clearFormats();
  delaySheet.setConditionalFormatRules([]); 
  delaySheet.getRange(1, 1, 1, 17).setValues(headers);

  if (delayedRows.length > 0) {
    const numRows = delayedRows.length;
    const targetRange = delaySheet.getRange(2, 1, numRows, 17);
    targetRange.setValues(delayedRows);
    targetRange.sort({column: 3, ascending: true});
    
    const flagRange = delaySheet.getRange(2, 2, numRows, 1);
    const newRules = [
      SpreadsheetApp.newConditionalFormatRule().whenTextContains("🔴").setBackground("#FFD1D1").setRanges([flagRange]).build(),
      SpreadsheetApp.newConditionalFormatRule().whenTextContains("🟠").setBackground("#FFE5CC").setRanges([flagRange]).build(),
      SpreadsheetApp.newConditionalFormatRule().whenTextContains("🟡").setBackground("#FFFFE0").setRanges([flagRange]).build()
    ];
    delaySheet.setConditionalFormatRules(newRules);
    delaySheet.getRange(2, 3, numRows, 2).setNumberFormat("dd/mm/yyyy hh:mm:ss");
  } else {
    delaySheet.getRange(2, 1).setValue("No orders currently delayed.");
  }
}
